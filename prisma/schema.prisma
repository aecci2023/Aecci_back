generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

type InternationalId {
  type     String
  idNumber String
}

type UploadedFile {
  name String
  url  String
  type String // e.g. "product_catalogue", "document"
}

model User {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  email          String  @unique
  countryCode    String?
  mobileNumber   String?
  password       String?
  fullName       String?
  country        String?
  userType       String?
  companyName    String?

  // OTP Verification
  isEmailVerified   Boolean   @default(false)
  emailOtp          String?
  emailOtpExpiry    DateTime?
  applicationNumber String?

  // Subscription Info
  planName        String?   // "explorer", "growth", "market_entry", "enterprise"
  planActive      Boolean   @default(false)
  planExpiresAt   DateTime?
  slotsTotal      Int       @default(0)
  slotsRemaining  Int       @default(0)

  // Onboarding Fields - Global Business
  websiteUrl         String?
  linkedinUrl        String?
  yearEstablished    String?
  companySize        String?
  turnover           String?
  importVolume       String?
  industrySector     String?
  businessAddress    String?
  legalStructure     String?
  businessRole       String[]
  products           String[]
  targetMarkets      String[]
  keyCertifications  String[]

  // Onboarding Fields - Global Individual
  professionalTitle  String?
  nationality        String?
  linkedinProfileUrl String?
  yearsOfExperience  String?
  experience         String?
  objective          String?
  
  // Specific Identifiers
  iecNumber           String?
  gstNumber           String?
  panNumber           String?
  aadharNumber        String?
  internationalBusinessIds InternationalId[]
  internationalIds    InternationalId[]

  expertiseAreas      String[]
  sectorsOfInterest   String[]
  languagesSpoken     String[]

  // Optional registration fields
  referralSource         String?
  businessAssociation    String?
  reportsUsed            Int       @default(0)

  profilePicture         String?
  // Documents
  iecDocument            String?
  gstDocument            String?
  panDocument            String?
  companyProfileDocument String?
  uploadedFiles          UploadedFile[]

  verificationStatus   String  @default("pending_verification") // pending_verification, approved, active, rejected
  rejectionReason      String?
  role                 String  @default("user") // user, admin, partner
  hasCompletedTour     Boolean @default(false)

  // Post-Onboarding Partner & Pricing Flow
  partnerId           String?   @db.ObjectId
  partner             User?     @relation("PartnerAssignment", fields: [partnerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedClients     User[]    @relation("PartnerAssignment")
  assignedPartnerFee  Float?
  assignedPartnerSlot DateTime?

  // New Relations for Deal Room Flow
  sessionsHosted    Session[]             @relation("SessionHost")
  sessionsClient    Session[]             @relation("SessionClient")
  registrations     SessionRegistration[]
  questionsAsked    Question[]            @relation("QuestionAuthor")
  questionsAssigned Question[]            @relation("QuestionAssignee")
  reports           OpportunityReport[]
  servicePurchases      ServicePurchase[]
  subscriptionPurchases SubscriptionPurchase[]
  messagesSent          Message[]             @relation("MessageSender")
  messagesReceived      Message[]             @relation("MessageReceiver")
  auditLogs             AuditLog[]
  partnerProfile        PartnerProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  country         String
  marketOverview  String?
  rules           String?
  date            DateTime
  durationMinutes Int
  seatsTotal      Int
  seatsAvailable  Int
  price           Float
  status          String   @default("upcoming") // upcoming, live, completed

  partnerId String @db.ObjectId
  partner   User   @relation("SessionHost", fields: [partnerId], references: [id])

  clientId      String?  @db.ObjectId
  client        User?    @relation("SessionClient", fields: [clientId], references: [id])
  questionnaire String?
  postSessionSummary String?

  registrations SessionRegistration[]
  reports       OpportunityReport[]
  questions     Question[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SessionRegistration {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  userId           String    @db.ObjectId
  sessionId        String    @db.ObjectId
  paymentStatus    String    @default("pending") // pending, paid
  paymentReference String?
  transactionId    String?
  invoiceUrl       String?
  joinedAt         DateTime?

  user    User    @relation(fields: [userId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, sessionId])
}

model CountryIntelligence {
  id                    String @id @default(auto()) @map("_id") @db.ObjectId
  country               String @unique
  marketOverview        String
  importRequirements    String
  distributionStructure String
  opportunities         String
  risks                 String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Question {
  id      String  @id @default(auto()) @map("_id") @db.ObjectId
  type    String // Product, Market, Expansion
  content String
  status  String  @default("pending") // pending, answered
  answer  String?

  userId String @db.ObjectId
  user   User   @relation("QuestionAuthor", fields: [userId], references: [id])

  partnerId String? @db.ObjectId
  partner   User?   @relation("QuestionAssignee", fields: [partnerId], references: [id])

  sessionId String?  @db.ObjectId
  session   Session? @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OpportunityReport {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  marketSummary   String
  potentialRoutes String
  recommendations String
  pdfUrl          String?

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  sessionId String  @db.ObjectId
  session   Session @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
}

model ServicePurchase {
  id            String  @id @default(auto()) @map("_id") @db.ObjectId
  serviceType   String // Advisory, Documentation, Partner Coordination, Market Entry
  price         Float
  paymentStatus String  @default("pending") // pending, paid, invoiced
  invoiceUrl    String?

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Message {
  id      String  @id @default(auto()) @map("_id") @db.ObjectId
  type    String  @default("notification") // support, partner, notification
  subject String?
  content String
  isRead  Boolean @default(false)

  senderId String? @db.ObjectId // Optional: system notifications have no sender
  sender   User?   @relation("MessageSender", fields: [senderId], references: [id])

  receiverId String @db.ObjectId
  receiver   User   @relation("MessageReceiver", fields: [receiverId], references: [id])

  createdAt DateTime @default(now())
}

model AuditLog {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  action    String // e.g., 'accepted_booking_terms', 'joined_live_room'
  ipAddress String?
  metadata  Json? // Stores browser info, timestamps, exact terms agreed to

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model PartnerProfile {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Application Info
  organization       String?
  expertiseCountries String[]
  expertiseSectors   String[]
  motivation         String?

  // Verification Docs
  governmentId     String?
  professionalCert String?
  businessProof    String?
  references       String?

  // Admin Assigned
  tier   String @default("Standard") // Standard, Premium, Specialist
  status String @default("pending_review") // pending_review, approved, active, suspended

  // Setup Info
  bio          String?
  availability Json? // Array of available slots/days

  // Legal
  signedAgreement Boolean   @default(false)
  agreementDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubscriptionPurchase {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @db.ObjectId
  user             User     @relation(fields: [userId], references: [id])
  planName         String   // "explorer", "growth", "market_entry", "enterprise"
  amount           Float
  currency         String   @default("INR")
  paymentStatus    String   @default("pending") // pending, paid, failed
  paymentReference String?  // Razorpay payment ID
  orderId          String?  // Razorpay order ID
  invoiceUrl       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model JobApplication {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  basicQualification String
  positionAppliedFor String
  address            String
  phoneNumber        String
  cvUrl              String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model InterestSubmission {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  category              String?
  userType              String?
  companyName           String?
  email                 String
  emailAddress          String?
  country               String?
  sector                String?
  contactPerson         String?
  fullName              String?
  cityState             String?
  countryCode           String?
  phoneWhatsapp         String?
  yourCountry           String?
  objectives            String[]
  products              String?
  targetMarkets         String[]
  sourcingRequirements  String?
  targetSourcingMarkets String[]
  expertiseAreas        String?
  sectorsOfInterest     String?
  professionalTitle     String?
  yearsOfExperience     String?
  infoAccurate          Boolean  @default(false)
  agreeTerms            Boolean  @default(false)
  understandFacilitation Boolean @default(false)
  shareInfo             Boolean  @default(false)
  status                String   @default("pending")

  createdAt             DateTime @default(now())
}
